{
  "name": "roms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Recruitment to Onboarding Management System",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @roms/server dev\" \"pnpm --filter @roms/client dev\"",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @roms/server prisma:migrate",
    "db:studio": "pnpm --filter @roms/server prisma:studio",
    "postinstall": "pnpm --filter @roms/shared build"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "typescript-eslint": "^8.21.0"
  }
}
